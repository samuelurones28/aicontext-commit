{
  "name": "aicontext-commit",
  "version": "0.1.0",
  "description": "CLI tool that generates commit messages by analyzing the repository history with AI",
  "bin": {
    "aicontext-commit": "./bin/index.js",
    "acc": "./bin/index.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node bin/index.js",
    "test": "npm run build && node --test tests/*.test.js",
    "smoke": "npm run build && npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "openai",
    "cli",
    "conventional-commits"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelurones28/aicontext-commit.git"
  },
  "author": "Samuelurones28",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@inquirer/prompts": "^4.0.0",
    "commander": "^12.0.0",
    "dotenv": "^17.4.2",
    "execa": "^8.0.0",
    "openai": "^4.28.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
