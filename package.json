{
  "name": "aicontext-commit",
  "version": "0.1.0",
  "description": "Herramienta CLI que genera mensajes de commit analizando el historial del repositorio con IA",
  "type": "module",
  "bin": {
    "aicontext-commit": "./bin/index.js",
    "acc": "./bin/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node bin/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "openai",
    "cli",
    "conventional-commits"
  ],
  "author": "Tu Nombre",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@inquirer/prompts": "^4.0.0",
    "commander": "^12.0.0",
    "execa": "^8.0.0",
    "openai": "^4.28.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
